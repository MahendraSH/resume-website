---
import '../styles/global.css';
import { APP_CONFIG } from '../config';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, any>;
  robots?: string;
}

const { 
  title = `${APP_CONFIG.name} | Portfolio & Resume`, 
  description = APP_CONFIG.description,
  schema,
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || APP_CONFIG.domain).toString();
const ogImageURL = new URL('/og-dark.png', Astro.site || APP_CONFIG.domain).toString();

// Default structured data schema for Person / Portfolio SEO (Rich Schema Graph)
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": APP_CONFIG.author.name,
    "alternateName": "Mahendra Shongunti",
    "jobTitle": "Full-Stack Developer",
    "worksFor": {
      "@type": "Organization",
      "name": "Infosys"
    },
    "description": APP_CONFIG.description,
    "url": APP_CONFIG.domain,
    "image": "https://github.com/MahendraSH.png",
    "email": APP_CONFIG.author.email,
    "telephone": APP_CONFIG.author.phone,
    "sameAs": [
      APP_CONFIG.socials.github,
      APP_CONFIG.socials.linkedin,
      APP_CONFIG.socials.twitter,
      APP_CONFIG.socials.medium,
      APP_CONFIG.socials.upwork
    ].filter(Boolean),
    "knowsAbout": [
      "Full-Stack Development",
      "Java",
      "Spring Boot",
      "React.js",
      "TypeScript",
      "ServiceNow SDK",
      "PostgreSQL",
      "Next.js"
    ]
  }
};

const jsonLd = schema || defaultSchema;
---

<!doctype html>
<html lang="en" class="dark bg-zinc-950 text-zinc-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/logo-dark.png" media="(prefers-color-scheme: light)" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Search Engine Crawling instructions -->
    <meta name="robots" content={robots} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Mahendra S H, Specialist Programmer, Fullstack Developer, React, Next.js, ServiceNow SDK, TypeScript" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Mahendra S H" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    <meta property="twitter:site" content="@mahendrash" />

    <!-- Structured Data JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen bg-zinc-950 font-sans antialiased text-zinc-50 selection:bg-blue-600 selection:text-white flex flex-col">
    <!-- Global Background Design Systems -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none bg-zinc-950">
      <!-- Soft Light Gray Dot Grid with a smooth radial mask -->
      <div class="absolute inset-0 bg-grid-dots-light-gray opacity-70" style="mask-image: radial-gradient(circle at 50% 30%, black 20%, transparent 85%); -webkit-mask-image: radial-gradient(circle at 50% 30%, black 20%, transparent 85%);"></div>
      
      <!-- Glowing Ambient Light Spheres (Orbs) -->
      <div class="absolute top-[-10%] left-[-10%] w-[55%] h-[55%] rounded-full bg-blue-600/10 blur-[130px] animate-drift-slow"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[55%] h-[55%] rounded-full bg-purple-600/8 blur-[130px] animate-drift-reverse"></div>
      <div class="absolute top-[35%] right-[15%] w-[35%] h-[35%] rounded-full bg-cyan-600/6 blur-[110px] animate-pulse-slow"></div>
      <div class="absolute bottom-[25%] left-[10%] w-[30%] h-[30%] rounded-full bg-indigo-600/5 blur-[100px] animate-pulse-slow"></div>
    </div>

    <slot />
    <CommandPalette />
  </body>
</html>
