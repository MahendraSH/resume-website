---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Mahendra S H | Portfolio & Resume"
  description="Portfolio website of Mahendra S H, a Full-Stack Developer and Specialist Programmer specializing in Spring Boot, React, TypeScript, and ServiceNow SDK. Explore my software projects and professional journey."
>
  <Navbar />
  
  <main class="w-full max-w-7xl 2xl:max-w-[90rem] mx-auto px-4 md:px-8 2xl:px-12 space-y-6">
    <!-- Hero (About) Section -->
    <Hero />

    <!-- Technical Skills Section -->
    <Skills />

    <!-- Experience Timeline Section -->
    <Experience />

    <!-- Education Timeline Section -->
    <Education />

    <!-- Projects Portfolio Section -->
    <Projects />
  </main>

  <Footer />
</Layout>
