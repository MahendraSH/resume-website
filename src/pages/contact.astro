---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { APP_CONFIG } from '../config';
---

<Layout title={`Contact | ${APP_CONFIG.name}`}>
  <Navbar />

  <main class="w-full max-w-4xl mx-auto px-4 md:px-8 py-16 md:py-24 space-y-12">
    <!-- Page Header -->
    <div class="text-center space-y-4 max-w-xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-zinc-50 leading-tight">
        Get in Touch
      </h1>
      <p class="text-zinc-400 text-sm md:text-base leading-relaxed">
        I am open to discussing new opportunities, collaboration ideas, or simply answering questions. Feel free to reach out to me through any of the channels below.
      </p>
    </div>

    <!-- Contact Cards Grid -->
    <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
      <!-- Email Card -->
      <a 
        href={`mailto:${APP_CONFIG.author.email}`} 
        class="group glass-panel p-6 rounded-2xl flex items-center gap-5 hover:bg-zinc-900/40 hover:border-blue-500/30 hover:scale-[1.02] transition-all duration-300"
      >
        <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400 group-hover:bg-blue-500/20 group-hover:text-blue-300 transition-colors">
          <!-- Mail Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </div>
        <div class="text-left space-y-1">
          <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">Email</div>
          <div class="text-sm font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors">{APP_CONFIG.author.email}</div>
        </div>
      </a>

      <!-- Phone Card -->
      <a 
        href={`tel:${APP_CONFIG.author.phone.replace(/-/g, '')}`} 
        class="group glass-panel p-6 rounded-2xl flex items-center gap-5 hover:bg-zinc-900/40 hover:border-blue-500/30 hover:scale-[1.02] transition-all duration-300"
      >
        <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400 group-hover:bg-blue-500/20 group-hover:text-blue-300 transition-colors">
          <!-- Phone Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
        </div>
        <div class="text-left space-y-1">
          <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">Phone</div>
          <div class="text-sm font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors">{APP_CONFIG.author.phone}</div>
        </div>
      </a>

      <!-- LinkedIn Card -->
      <a 
        href={APP_CONFIG.socials.linkedin} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="group glass-panel p-6 rounded-2xl flex items-center gap-5 hover:bg-zinc-900/40 hover:border-blue-500/30 hover:scale-[1.02] transition-all duration-300"
      >
        <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400 group-hover:bg-blue-500/20 group-hover:text-blue-300 transition-colors">
          <!-- LinkedIn Icon -->
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
          </svg>
        </div>
        <div class="text-left space-y-1">
          <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">LinkedIn</div>
          <div class="text-sm font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors">mahendra-s-h-14a74721a</div>
        </div>
      </a>

      <!-- GitHub Card -->
      <a 
        href={APP_CONFIG.socials.github} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="group glass-panel p-6 rounded-2xl flex items-center gap-5 hover:bg-zinc-900/40 hover:border-blue-500/30 hover:scale-[1.02] transition-all duration-300"
      >
        <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400 group-hover:bg-blue-500/20 group-hover:text-blue-300 transition-colors">
          <!-- GitHub Icon -->
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.44 22 12.017 22 6.484 17.522 2 12 2z"/>
          </svg>
        </div>
        <div class="text-left space-y-1">
          <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">GitHub</div>
          <div class="text-sm font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors">github.com/MahendraSH</div>
        </div>
      </a>

      <!-- X / Twitter Card -->
      {APP_CONFIG.socials.twitter && (
        <a 
          href={APP_CONFIG.socials.twitter} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group glass-panel p-6 rounded-2xl flex items-center gap-5 hover:bg-zinc-900/40 hover:border-blue-500/30 hover:scale-[1.02] transition-all duration-300"
        >
          <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400 group-hover:bg-blue-500/20 group-hover:text-blue-300 transition-colors">
            <!-- X Icon -->
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </div>
          <div class="text-left space-y-1">
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">X / Twitter</div>
            <div class="text-sm font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors">@mahendrashon</div>
          </div>
        </a>
      )}

      <!-- Medium Card -->
      {APP_CONFIG.socials.medium && (
        <a 
          href={APP_CONFIG.socials.medium} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group glass-panel p-6 rounded-2xl flex items-center gap-5 hover:bg-zinc-900/40 hover:border-blue-500/30 hover:scale-[1.02] transition-all duration-300"
        >
          <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400 group-hover:bg-blue-500/20 group-hover:text-blue-300 transition-colors">
            <!-- Medium Icon -->
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42zm3.04 0c0 3.25-.33 5.9-0.73 5.9-.4 0-.73-2.65-.73-5.9s.33-5.9.73-5.9c.4 0 .73 2.65.73 5.9z"/>
            </svg>
          </div>
          <div class="text-left space-y-1">
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">Medium</div>
            <div class="text-sm font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors">@maahi2001sh</div>
          </div>
        </a>
      )}

      <!-- Location Card (spanning 2 columns on larger screens) -->
      <div 
        class="glass-panel p-6 rounded-2xl flex items-center gap-5 md:col-span-2"
      >
        <div class="p-3.5 bg-blue-500/10 rounded-xl text-blue-400">
          <!-- Pin Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
        </div>
        <div class="text-left space-y-1">
          <div class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono font-bold">Location</div>
          <div class="text-sm font-semibold text-zinc-200">Karnataka, India</div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
