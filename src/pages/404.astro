---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { APP_CONFIG } from '../config';
---

<Layout title={`404: Page Not Found | ${APP_CONFIG.name}`}>
  <Navbar />

  <main class="w-full max-w-4xl mx-auto px-4 md:px-8 py-20 md:py-32 flex flex-col items-center justify-center relative overflow-hidden min-h-[calc(100vh-13.5rem)]">
    
    <!-- Floating Blur Glow Elements -->
    <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl -z-10 animate-drift-slow pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-blue-400/5 rounded-full blur-3xl -z-10 animate-drift-reverse pointer-events-none"></div>
    
    <div class="text-center space-y-8 z-10">
      
      <!-- Icon & Status Code -->
      <div class="relative inline-block">
        <span class="absolute -inset-1 rounded-full bg-blue-500/20 blur-md opacity-75 animate-pulse"></span>
        <div class="relative px-6 py-2 rounded-full border border-blue-500/30 bg-zinc-950/60 backdrop-blur-sm text-blue-400 font-mono text-xs font-semibold tracking-widest uppercase">
          Error 404
        </div>
      </div>

      <!-- Large glowing 404 Text -->
      <div class="relative select-none">
        <h1 class="text-8xl md:text-9xl font-extrabold tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-zinc-100 to-zinc-500 opacity-90">
          404
        </h1>
        <div class="absolute inset-0 bg-gradient-to-t from-blue-500/10 to-transparent blur-xl pointer-events-none"></div>
      </div>

      <!-- Header Content -->
      <div class="space-y-3 max-w-lg mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-100">
          Lost in Space?
        </h2>
        <p class="text-zinc-400 text-sm md:text-base leading-relaxed">
          The page you are looking for doesn't exist, has been moved, or perhaps never existed in this dimension.
        </p>
      </div>

      <!-- Interactive Term/Snippet Mockup -->
      <div class="max-w-md mx-auto rounded-xl border border-zinc-850 bg-zinc-900/40 backdrop-blur-sm p-4 font-mono text-left text-xs text-zinc-400 shadow-xl">
        <div class="flex items-center gap-1.5 pb-3 border-b border-zinc-850/60 mb-3">
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
          <span class="ml-2 text-[10px] text-zinc-500">guest@mahendra.sh:~</span>
        </div>
        <div class="space-y-1.5">
          <p><span class="text-blue-400">~/resume-website</span> <span class="text-zinc-500">$</span> curl -I {APP_CONFIG.domain}{Astro.url.pathname}</p>
          <p class="text-zinc-500">HTTP/2 404 Not Found</p>
          <p class="text-zinc-500">Content-Type: text/html; charset=UTF-8</p>
          <p class="text-zinc-500">Message: Requested route could not be resolved.</p>
          <p class="animate-pulse"><span class="text-blue-400">~/resume-website</span> <span class="text-zinc-500">$</span> <span class="w-2 h-4 bg-zinc-400 inline-block align-middle"></span></p>
        </div>
      </div>

      <!-- Actions & Redirection -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <a 
          href="/" 
          class="w-full sm:w-auto px-6 py-2.5 rounded-xl bg-zinc-100 hover:bg-zinc-200 text-zinc-950 text-xs font-semibold font-mono tracking-wide transition border border-zinc-200 shadow-sm cursor-pointer text-center"
        >
          Go Back Home
        </a>
        
        <button 
          type="button"
          data-command-palette-trigger
          class="w-full sm:w-auto px-6 py-2.5 rounded-xl bg-zinc-900 hover:bg-zinc-800 text-zinc-300 hover:text-zinc-100 text-xs font-semibold font-mono tracking-wide transition border border-zinc-850 cursor-pointer flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Search Site
          <kbd class="hidden sm:inline-block text-[9px] font-sans text-zinc-500 bg-zinc-950 border border-zinc-900 px-1 rounded ml-1">⌘K</kbd>
        </button>
      </div>

      <!-- Quick Links Map -->
      <div class="pt-8 border-t border-zinc-900/60 max-w-sm mx-auto">
        <p class="text-[10px] text-zinc-550 uppercase tracking-widest font-mono font-bold mb-4">Quick Navigation</p>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs font-mono">
          <a href="/#about" class="text-zinc-400 hover:text-blue-400 transition-colors">About</a>
          <a href="/#projects" class="text-zinc-400 hover:text-blue-400 transition-colors">Projects</a>
          <a href="/miscellaneous" class="text-zinc-400 hover:text-blue-400 transition-colors">Miscellaneous</a>
          <a href="/contact" class="text-zinc-400 hover:text-blue-400 transition-colors">Contact</a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
