---
import Logo from './Logo.astro';
import { APP_CONFIG } from '../config';

const currentPath = Astro.url.pathname;
---

<header class="w-full h-14 border-b border-zinc-850 px-4 md:px-6 flex items-center justify-between shrink-0 bg-zinc-950/80 backdrop-blur-md z-30 sticky top-0 font-sans">
  <div class="flex items-center gap-6">
    <a href="/" class="transition hover:opacity-90">
      <Logo />
    </a>
  </div>

  <!-- Navigation Links -->
  <nav class="hidden md:flex items-center gap-6 text-xs font-mono">
    <a href="/#about" class="transition-colors hover:text-zinc-100 text-zinc-400 font-medium">About</a>
    <a href="/#skills" class="transition-colors hover:text-zinc-100 text-zinc-400 font-medium">Skills</a>
    <a href="/#experience" class="transition-colors hover:text-zinc-100 text-zinc-400 font-medium">Experience</a>
    <a href="/#education" class="transition-colors hover:text-zinc-100 text-zinc-400 font-medium">Education</a>
    <a href="/#projects" class="transition-colors hover:text-zinc-100 text-zinc-400 font-medium">Projects</a>
    <a href="/contact" class={`transition-colors hover:text-zinc-100 font-medium ${currentPath === '/contact' || currentPath === '/contact/' ? 'text-blue-400 font-bold' : 'text-zinc-400'}`}>Contact</a>
  </nav>

  <!-- Right Actions -->
  <div class="flex items-center gap-3">
    <!-- Social Links -->
    <a 
      href={APP_CONFIG.socials.github} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="text-zinc-400 hover:text-zinc-100 transition p-1 hidden sm:inline-block"
      aria-label="GitHub Profile"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.44 22 12.017 22 6.484 17.522 2 12 2z"/>
      </svg>
    </a>
    <a 
      href={APP_CONFIG.socials.linkedin} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="text-zinc-400 hover:text-zinc-100 transition p-1 hidden sm:inline-block"
      aria-label="LinkedIn Profile"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" fill="currentColor" />
      </svg>
    </a>
    
    <a 
      href="/mahendra_sh_resume.pdf" 
      download="mahendra_sh_resume.pdf"
      class="px-3 py-1.5 rounded bg-zinc-50 hover:bg-zinc-200 text-zinc-950 text-[10px] font-bold font-mono transition border border-zinc-200 shadow-sm cursor-pointer"
    >
      Download CV
    </a>

    <!-- Mobile Menu Button -->
    <button 
      id="mobile-menu-toggle"
      type="button" 
      class="md:hidden p-1 text-zinc-400 hover:text-zinc-200 cursor-pointer"
      aria-label="Toggle Navigation Drawer"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Navigation Drawer -->
<div 
  id="mobile-drawer" 
  class="fixed inset-0 z-45 bg-zinc-950/95 backdrop-blur-md hidden flex-col justify-between p-6 border-b border-zinc-900 font-mono transition-transform duration-300"
>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <Logo />
      <button 
        id="mobile-drawer-close"
        type="button" 
        class="p-1 text-zinc-400 hover:text-zinc-200 cursor-pointer"
        aria-label="Close Drawer"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <nav class="flex flex-col gap-4 text-sm pt-6 border-t border-zinc-900">
      <a href="/#about" class="mobile-nav-link text-zinc-400 hover:text-zinc-100 py-2">About</a>
      <a href="/#skills" class="mobile-nav-link text-zinc-400 hover:text-zinc-100 py-2">Skills</a>
      <a href="/#experience" class="mobile-nav-link text-zinc-400 hover:text-zinc-100 py-2">Experience</a>
      <a href="/#education" class="mobile-nav-link text-zinc-400 hover:text-zinc-100 py-2">Education</a>
      <a href="/#projects" class="mobile-nav-link text-zinc-400 hover:text-zinc-100 py-2">Projects</a>
      <a href="/contact" class="mobile-nav-link text-zinc-400 hover:text-zinc-100 py-2">Contact</a>
    </nav>
  </div>
  
  <div class="pt-6 border-t border-zinc-900 flex justify-between items-center text-xs text-zinc-500">
    <span>© {new Date().getFullYear()} {APP_CONFIG.name}</span>
    <div class="flex gap-3">
      <a href={APP_CONFIG.socials.github} target="_blank" rel="noopener" class="underline">GitHub</a>
      <a href={APP_CONFIG.socials.linkedin} target="_blank" rel="noopener" class="underline">LinkedIn</a>
    </div>
  </div>
</div>

<script>
  function setupNavbar() {
    // Mobile drawer toggle
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-drawer-close');
    const drawer = document.getElementById('mobile-drawer');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    if (toggleBtn && drawer && closeBtn) {
      toggleBtn.addEventListener('click', () => {
        drawer.classList.remove('hidden');
        drawer.classList.add('flex');
      });
      closeBtn.addEventListener('click', () => {
        drawer.classList.add('hidden');
        drawer.classList.remove('flex');
      });
      
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          drawer.classList.add('hidden');
          drawer.classList.remove('flex');
        });
      });
    }
  }

  // Load listeners
  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
</script>
