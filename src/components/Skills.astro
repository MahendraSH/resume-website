---
import { SKILL_CATEGORIES } from '../config';
---

<section id="skills" class="w-full py-12">
  <div class="glass-panel p-6 md:p-10 rounded-2xl space-y-6">
    <div>
      <h2 class="text-2xl md:text-3xl font-bold font-sans text-zinc-50 tracking-tight">Tech Skills</h2>
      <p class="text-xs md:text-sm text-zinc-450 mt-1">
        Technologies, frameworks, databases, and tools I've worked with.
      </p>
    </div>

    <!-- Separator Line -->
    <div class="h-[1px] w-full bg-zinc-850"></div>

    <!-- Skills Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {SKILL_CATEGORIES.map((cat) => (
        <div 
          class="p-5 rounded-xl border border-zinc-850 bg-zinc-900/30 hover:bg-zinc-900/50 hover:border-zinc-800 transition-all duration-300 shadow-sm flex flex-col justify-start group"
        >
          <h3 class="font-bold text-sm text-blue-400 uppercase font-mono tracking-wide mb-4 transition-colors group-hover:text-blue-300">
            {cat.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <kbd 
                class="px-2.5 py-1 text-[11px] font-semibold rounded bg-zinc-900 text-zinc-300 border border-zinc-850 hover:border-zinc-700 hover:text-zinc-100 transition-colors duration-200"
              >
                {skill}
              </kbd>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
