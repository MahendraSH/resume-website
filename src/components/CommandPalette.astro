---
import { PROJECTS, APP_CONFIG } from '../config';
---

<!-- Backdrop overlay -->
<div 
  id="command-palette-backdrop" 
  class="fixed inset-0 z-[100] bg-zinc-950/70 backdrop-blur-xs flex items-start justify-center pt-[15vh] px-4 opacity-0 pointer-events-none transition-all duration-200 ease-out"
>
  <!-- Modal container -->
  <div 
    id="command-palette-container"
    class="w-full max-w-lg bg-zinc-900 border border-zinc-800/80 rounded-xl shadow-2xl overflow-hidden glass-panel scale-95 opacity-0 transition-all duration-200 ease-out flex flex-col max-h-[55vh]"
  >
    <!-- Search Header -->
    <div class="flex items-center gap-3 px-4 py-3.5 border-b border-zinc-850">
      <!-- Search Icon -->
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <!-- Input -->
      <input 
        type="text" 
        id="command-palette-input" 
        placeholder="Type a command or search..." 
        class="w-full bg-transparent text-sm text-zinc-200 placeholder-zinc-500 border-none outline-none focus:ring-0 py-0.5 font-sans"
        autocomplete="off"
        spellcheck="false"
      />
      <!-- Close Badge -->
      <kbd class="px-1.5 py-0.5 text-[9px] font-mono bg-zinc-950 text-zinc-500 border border-zinc-850 rounded shadow-xs select-none">ESC</kbd>
    </div>

    <!-- Commands List -->
    <div 
      id="command-palette-list" 
      class="flex-1 overflow-y-auto py-2 divide-y divide-zinc-850/25 scrollbar-none"
    >
      <!-- Category: Navigation -->
      <div class="command-group py-1" data-group="navigation">
        <div class="px-4 py-1.5 text-[9px] font-bold text-zinc-500 uppercase tracking-widest font-mono select-none">Navigation</div>
        
        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="about section home bio introduction summary profile me mahendra"
          data-action="scroll"
          data-target="#about"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">About Section</span>
              <span class="text-[10px] text-zinc-500 font-sans">Biography, background, and summary</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Section</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="skills section technical stack languages frameworks libraries databases tools backend frontend cloud"
          data-action="scroll"
          data-target="#skills"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Skills Section</span>
              <span class="text-[10px] text-zinc-500 font-sans">Technical stack and expertise mapping</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Section</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="experience section timeline history jobs employment role career infosys merav developer coding"
          data-action="scroll"
          data-target="#experience"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Experience Section</span>
              <span class="text-[10px] text-zinc-500 font-sans">Professional career timeline</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Section</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="education section degree coursework btech studies college university nie"
          data-action="scroll"
          data-target="#education"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Education Section</span>
              <span class="text-[10px] text-zinc-500 font-sans">Academic background and qualifications</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Section</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="projects section list showcase portfolio tools creations work open source"
          data-action="scroll"
          data-target="#projects"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Projects Section</span>
              <span class="text-[10px] text-zinc-500 font-sans">Portfolio of development work</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Section</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="contact page hire email phone message form reach out"
          data-action="navigate"
          data-target="/contact"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L22 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Contact Page</span>
              <span class="text-[10px] text-zinc-500 font-sans">Send a message or find contact details</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Page</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="tools page miscellaneous works side projects utilities logo generator json markdown pg spring db editor"
          data-action="navigate"
          data-target="/miscellaneous"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Tools & Utilities</span>
              <span class="text-[10px] text-zinc-500 font-sans">Miscellaneous developer tools and side projects</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Page</span>
        </button>
      </div>

      <!-- Category: Projects -->
      <div class="command-group py-1" data-group="projects">
        <div class="px-4 py-1.5 text-[9px] font-bold text-zinc-500 uppercase tracking-widest font-mono select-none">Projects</div>
        {PROJECTS.map((project) => {
          const searchStr = `${project.name} ${project.description} ${project.category} ${project.labels.join(" ")}`.toLowerCase();
          return (
            <button
              type="button"
              class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
              data-search={searchStr}
              data-action="project"
              data-target={`#project-${project.id}`}
              data-project-id={project.id}
              data-is-tool={project.category === "Tools" ? "true" : "false"}
            >
              <div class="flex items-center gap-3 max-w-[85%]">
                <!-- Terminal icon for developer tools, cube for other things -->
                {project.category === "Tools" || project.category === "Community Tool" ? (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-400/80 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400/80 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                  </svg>
                )}
                <div class="flex flex-col truncate">
                  <span class="text-xs font-medium truncate">{project.name}</span>
                  <span class="text-[10px] text-zinc-500 truncate font-mono">{project.category} // {project.labels.slice(0, 3).join(", ")}</span>
                </div>
              </div>
              <span class="text-[9px] font-mono text-zinc-500 whitespace-nowrap">Project</span>
            </button>
          );
        })}
      </div>

      <!-- Category: Actions -->
      <div class="command-group py-1" data-group="actions">
        <div class="px-4 py-1.5 text-[9px] font-bold text-zinc-500 uppercase tracking-widest font-mono select-none">Quick Actions</div>
        
        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="download cv resume pdf document stats details"
          data-action="download"
          data-target="/mahendra_sh_resume.pdf"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Download CV / Resume</span>
              <span class="text-[10px] text-zinc-500 font-sans">Get the official PDF resume</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Download</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="github profile account external repository code git"
          data-action="url"
          data-target={APP_CONFIG.socials.github}
        >
          <div class="flex items-center gap-3">
            <!-- GitHub SVG -->
            <svg class="w-4 h-4 text-zinc-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.44 22 12.017 22 6.484 17.522 2 12 2z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">GitHub Profile</span>
              <span class="text-[10px] text-zinc-500 font-sans">Open github.com/MahendraSH</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">External</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="linkedin profile account social connect job recruiter"
          data-action="url"
          data-target={APP_CONFIG.socials.linkedin}
        >
          <div class="flex items-center gap-3">
            <!-- LinkedIn SVG -->
            <svg class="w-4 h-4 text-zinc-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" fill="currentColor" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">LinkedIn Profile</span>
              <span class="text-[10px] text-zinc-500 font-sans">Open LinkedIn professional network</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">External</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="upwork profile freelance contract hire developer coding work"
          data-action="url"
          data-target={APP_CONFIG.socials.upwork}
        >
          <div class="flex items-center gap-3">
            <!-- Upwork SVG or clean fallback -->
            <svg class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Upwork Freelance</span>
              <span class="text-[10px] text-zinc-500 font-sans">View Upwork profile for freelance contracts</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">External</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="email mail send contact write mahendrash gmail"
          data-action="email"
          data-target={`mailto:${APP_CONFIG.author.email}`}
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0V9a2 2 0 00-2-2M4 13V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Email Mahendra</span>
              <span class="text-[10px] text-zinc-500 font-sans">{APP_CONFIG.author.email}</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Email</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="call phone number mobile phone contact"
          data-action="phone"
          data-target={`tel:${APP_CONFIG.author.phone}`}
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Call Mahendra</span>
              <span class="text-[10px] text-zinc-500 font-sans">{APP_CONFIG.author.phone}</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Phone</span>
        </button>

        <button
          type="button"
          class="command-item w-full flex items-center justify-between px-4 py-2 text-left text-zinc-350 hover:bg-zinc-800/50 hover:text-zinc-100 transition-colors duration-100 outline-none cursor-pointer focus:bg-zinc-800/50 focus:text-zinc-100 select-none"
          data-search="scroll top up header beginning start"
          data-action="scroll-top"
          data-target="top"
        >
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
            </svg>
            <div class="flex flex-col">
              <span class="text-xs font-medium">Scroll to Top</span>
              <span class="text-[10px] text-zinc-500 font-sans">Go back to the top of the page</span>
            </div>
          </div>
          <span class="text-[9px] font-mono text-zinc-500">Action</span>
        </button>
      </div>
      
      <!-- No Results Placeholder -->
      <div id="command-palette-no-results" class="hidden py-8 px-4 text-center select-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-zinc-650 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-xs text-zinc-400 font-medium">No results found</p>
        <p class="text-[10px] text-zinc-550 mt-0.5">Try searching for sections, projects, or social links.</p>
      </div>
    </div>

    <!-- Footer Help -->
    <div class="px-4 py-2 border-t border-zinc-850/80 bg-zinc-950/40 flex items-center justify-between text-[10px] text-zinc-500 font-mono select-none">
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1"><kbd class="px-1 bg-zinc-900 border border-zinc-800 rounded">↑↓</kbd> Navigate</span>
        <span class="flex items-center gap-1"><kbd class="px-1 bg-zinc-900 border border-zinc-800 rounded">↵</kbd> Select</span>
      </div>
      <div>
        <span class="flex items-center gap-1"><kbd class="px-1 bg-zinc-900 border border-zinc-800 rounded">esc</kbd> Close</span>
      </div>
    </div>
  </div>
</div>

<script>
  let activeIndex = 0;
  let visibleItems: HTMLElement[] = [];

  function getElements() {
    return {
      backdrop: document.getElementById('command-palette-backdrop'),
      container: document.getElementById('command-palette-container'),
      input: document.getElementById('command-palette-input') as HTMLInputElement | null,
      list: document.getElementById('command-palette-list'),
      items: Array.from(document.querySelectorAll('.command-item')) as HTMLElement[],
      groups: Array.from(document.querySelectorAll('.command-group')) as HTMLElement[],
      noResults: document.getElementById('command-palette-no-results'),
      // Also grab dynamic trigger buttons
      triggers: Array.from(document.querySelectorAll('[data-command-palette-trigger]'))
    };
  }

  function openPalette() {
    const { backdrop, container, input } = getElements();
    if (!backdrop || !container) return;

    // Trigger visual opening
    backdrop.classList.remove('opacity-0', 'pointer-events-none');
    backdrop.classList.add('opacity-100', 'pointer-events-auto');
    container.classList.remove('scale-95', 'opacity-0');
    container.classList.add('scale-100', 'opacity-100');

    // Body scroll lock
    document.body.style.overflow = 'hidden';

    // Clear and focus input
    if (input) {
      input.value = '';
      setTimeout(() => input.focus(), 50);
    }

    // Filter list (reset view)
    filterItems('');
  }

  function closePalette() {
    const { backdrop, container, input } = getElements();
    if (!backdrop || !container) return;

    // Trigger visual closing
    container.classList.remove('scale-100', 'opacity-100');
    container.classList.add('scale-95', 'opacity-0');
    backdrop.classList.remove('opacity-100', 'pointer-events-auto');
    backdrop.classList.add('opacity-0', 'pointer-events-none');

    // Unlock body scroll
    document.body.style.overflow = '';

    // Unfocus input
    if (input) {
      input.blur();
    }
  }

  function filterItems(query: string) {
    const { items, groups, noResults } = getElements();
    const cleanQuery = query.toLowerCase().trim();

    visibleItems = [];

    // Hide or show items based on search terms
    items.forEach((item) => {
      const searchTerms = item.getAttribute('data-search') || '';
      if (!cleanQuery || searchTerms.includes(cleanQuery)) {
        item.classList.remove('hidden');
        visibleItems.push(item);
      } else {
        item.classList.add('hidden');
      }
    });

    // Hide or show groups depending on if they have visible children
    groups.forEach((group) => {
      const groupItems = Array.from(group.querySelectorAll('.command-item'));
      const hasVisibleItems = groupItems.some((item) => !item.classList.contains('hidden'));
      if (hasVisibleItems) {
        group.classList.remove('hidden');
      } else {
        group.classList.add('hidden');
      }
    });

    // Show/hide no results message
    if (noResults) {
      if (visibleItems.length === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    }

    // Reset active item index
    setActiveItem(0);
  }

  function setActiveItem(index: number) {
    // Clear previous active states
    visibleItems.forEach((item) => {
      item.classList.remove('bg-zinc-800/50', 'text-zinc-100');
      item.classList.add('text-zinc-350');
    });

    if (visibleItems.length === 0) {
      activeIndex = -1;
      return;
    }

    // Handle wrapping around
    if (index >= visibleItems.length) {
      activeIndex = 0;
    } else if (index < 0) {
      activeIndex = visibleItems.length - 1;
    } else {
      activeIndex = index;
    }

    // Highlight new active item
    const activeItem = visibleItems[activeIndex];
    if (activeItem) {
      activeItem.classList.remove('text-zinc-350');
      activeItem.classList.add('bg-zinc-800/50', 'text-zinc-100');
      activeItem.scrollIntoView({ block: 'nearest' });
    }
  }

  function handleAction(item: HTMLElement) {
    const action = item.getAttribute('data-action');
    const target = item.getAttribute('data-target') || '';
    const currentPath = window.location.pathname;

    closePalette();

    if (!action) return;

    if (action === 'scroll') {
      if (currentPath === '/' || currentPath === '/index.html') {
        const element = document.querySelector(target);
        if (element) {
          element.scrollIntoView({ behavior: 'smooth' });
          // Highlight scroll spy state
          history.pushState(null, '', target);
        }
      } else {
        // Redirect to homepage with hash anchor
        window.location.href = '/' + target;
      }
    } else if (action === 'project') {
      const isTool = item.getAttribute('data-is-tool') === 'true';
      if (isTool) {
        if (currentPath === '/miscellaneous' || currentPath === '/miscellaneous/') {
          const element = document.querySelector(target);
          if (element) {
            element.scrollIntoView({ behavior: 'smooth' });
            element.classList.add('ring-2', 'ring-blue-500/50', 'duration-500');
            setTimeout(() => {
              element.classList.remove('ring-2', 'ring-blue-500/50');
            }, 2000);
            history.pushState(null, '', target);
          }
        } else {
          window.location.href = '/miscellaneous' + target;
        }
      } else {
        if (currentPath === '/' || currentPath === '/index.html') {
          // If filter is active, click 'All' filter first to make the project visible
          const allFilterBtn = document.querySelector('[data-filter="All"]') as HTMLButtonElement | null;
          if (allFilterBtn) {
            allFilterBtn.click();
          }
          
          setTimeout(() => {
            const element = document.querySelector(target);
            if (element) {
              element.scrollIntoView({ behavior: 'smooth' });
              
              // Add a temporary subtle blink effect to highlight it
              element.classList.add('ring-2', 'ring-blue-500/50', 'duration-500');
              setTimeout(() => {
                element.classList.remove('ring-2', 'ring-blue-500/50');
              }, 2000);
              
              history.pushState(null, '', target);
            }
          }, 100);
        } else {
          window.location.href = '/' + target;
        }
      }
    } else if (action === 'navigate') {
      window.location.href = target;
    } else if (action === 'url') {
      window.open(target, '_blank', 'noopener,noreferrer');
    } else if (action === 'download') {
      const link = document.createElement('a');
      link.href = target;
      link.download = target.split('/').pop() || 'resume.pdf';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    } else if (action === 'email' || action === 'phone') {
      window.location.href = target;
    } else if (action === 'scroll-top') {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  }

  function setupCommandPalette() {
    const { backdrop, input, items, triggers } = getElements();
    if (!backdrop) return;

    // Hotkey listener (Cmd+K / Ctrl+K / Escape)
    const handleGlobalKeydown = (e: KeyboardEvent) => {
      const isOpen = !backdrop.classList.contains('opacity-0');

      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (isOpen) {
          closePalette();
        } else {
          openPalette();
        }
      } else if (e.key === 'Escape' && isOpen) {
        e.preventDefault();
        closePalette();
      }
    };

    // Keyboard navigation when open
    const handleModalKeydown = (e: KeyboardEvent) => {
      const isOpen = !backdrop.classList.contains('opacity-0');
      if (!isOpen) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActiveItem(activeIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActiveItem(activeIndex - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (activeIndex >= 0 && visibleItems[activeIndex]) {
          handleAction(visibleItems[activeIndex]);
        }
      }
    };

    // Mouse over selection and clicking
    items.forEach((item, index) => {
      item.addEventListener('mouseenter', () => {
        // Find visible index
        const visibleIdx = visibleItems.indexOf(item);
        if (visibleIdx !== -1) {
          setActiveItem(visibleIdx);
        }
      });

      item.addEventListener('click', (e) => {
        e.preventDefault();
        handleAction(item);
      });
    });

    // Input listening
    if (input) {
      input.addEventListener('input', (e) => {
        const val = (e.target as HTMLInputElement).value;
        filterItems(val);
      });
    }

    // Backdrop click to close
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) {
        closePalette();
      }
    });

    // Trigger button binding
    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        openPalette();
      });
    });

    // Setup global window listener
    window.removeEventListener('keydown', handleGlobalKeydown);
    window.addEventListener('keydown', handleGlobalKeydown);

    backdrop.removeEventListener('keydown', handleModalKeydown);
    backdrop.addEventListener('keydown', handleModalKeydown);
  }

  // Initial setup
  setupCommandPalette();

  // Astro page lifecycle support
  document.addEventListener('astro:after-swap', setupCommandPalette);
</script>
