---
import { APP_CONFIG } from '../config';
---

<section id="about" class="relative w-full min-h-[90vh] py-16 md:py-24 flex items-center justify-center px-4 md:px-8 overflow-hidden bg-transparent shrink-0">
  <!-- Fine Layout Structural Lines for Blueprint Aesthetic -->
  <div class="absolute inset-x-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent -z-15 opacity-60"></div>
  <div class="absolute inset-x-0 bottom-0 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent -z-15 opacity-60"></div>
  <div class="absolute inset-y-0 left-1/4 w-[1px] bg-gradient-to-b from-transparent via-zinc-900 to-transparent -z-15 hidden lg:block opacity-40"></div>
  <div class="absolute inset-y-0 right-1/4 w-[1px] bg-gradient-to-b from-transparent via-zinc-900 to-transparent -z-15 hidden lg:block opacity-40"></div>

  <!-- Corner System Accents -->
  <div class="absolute top-8 left-8 text-zinc-700 font-mono text-[9px] tracking-widest pointer-events-none select-none hidden lg:block -z-10">
    SYS.INIT // 0x7E1B
  </div>
  <div class="absolute bottom-8 right-8 text-zinc-700 font-mono text-[9px] tracking-widest pointer-events-none select-none hidden lg:block -z-10">
    LATENCY // 0.05ms
  </div>

  <div class="max-w-6xl w-full mx-auto z-10 relative">
    <div class="glass-panel p-6 md:p-12 rounded-3xl flex flex-col lg:flex-row items-center gap-10 md:gap-12">
      
      <!-- Profile Image Container with Bobbing & Liquid Morphing Wave Animations -->
      <div class="relative shrink-0 flex items-center justify-center profile-container">
        <!-- Neon Spinning border container -->
        <div class="relative w-64 h-64 md:w-80 md:h-80 overflow-hidden wavy-profile-image shadow-2xl flex items-center justify-center -z-0">
          <!-- The rotating gradient background -->
          <div class="absolute inset-0 bg-[conic-gradient(from_0deg,#22d3ee,#3b82f6,#d946ef,#22d3ee)] animate-spin-frame -z-10"></div>
          
          <!-- Inner Dark Shield -->
          <div class="absolute inset-[3px] bg-zinc-950 wavy-profile-image flex items-center justify-center p-1.5 overflow-hidden">
            <img
              src="https://github.com/MahendraSH.png"
              alt="Mahendra S H"
              class="w-full h-full object-cover wavy-profile-image"
            />
          </div>
        </div>
      </div>

      <!-- Hero Content -->
      <div class="flex-1 space-y-6 text-center lg:text-left">
        <div class="space-y-3">
          <!-- Open to Opportunities badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900/80 border border-zinc-850 text-[10px] font-mono tracking-wider text-emerald-400 uppercase w-fit">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
            <span>Open to Opportunities</span>
          </div>

          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-zinc-50 leading-tight">
            Mahendra S H
          </h1>
          
          <div class="h-8 md:h-10 text-lg md:text-xl font-mono text-zinc-350 flex justify-center lg:justify-start items-center">
            <span>I am a&nbsp;</span>
            <span id="typewriter" class="text-blue-400 font-bold border-r-2 border-blue-400 pr-1 min-h-[1.5em] flex items-center"></span>
          </div>
        </div>

        <p class="text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl mx-auto lg:mx-0">
          Full-Stack Developer with nearly 2 years of experience designing, developing, and maintaining high-performance, scalable web applications from concept to deployment. Proficient in architecting modular backend services, database design/optimization, and implementing automated batch processing pipelines, as well as building highly responsive, interactive user interfaces.
        </p>

        <!-- Current Role Summary Details Card -->
        <div class="p-4 rounded-xl border border-zinc-850 bg-zinc-900/50 max-w-xl mx-auto lg:mx-0 flex flex-col sm:flex-row items-center gap-4">
          <div class="text-center sm:text-left space-y-1">
            <div class="text-[10px] uppercase font-bold text-zinc-500 tracking-wider">Previous Role</div>
            <div class="text-sm font-semibold text-zinc-100">Specialist Programmer (ex-Infosys)</div>
          </div>
          <div class="hidden sm:block text-zinc-800">|</div>
          <div class="text-center sm:text-left space-y-1">
            <div class="text-[10px] uppercase font-bold text-zinc-500 tracking-wider">Experience</div>
            <div class="text-sm font-semibold text-zinc-100">2 Years Full-Stack</div>
          </div>
        </div>

        <!-- Contact/Email Info -->
        <div class="flex items-center justify-center lg:justify-start gap-2 text-xs font-mono text-zinc-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue-400/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href={`mailto:${APP_CONFIG.author.email}`} class="hover:text-blue-400 transition-colors">{APP_CONFIG.author.email}</a>
        </div>

        <!-- Social Icons & Download CTA -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-2">
          <!-- Social Link Group -->
          <div class="flex items-center gap-3">
            <a
              href={APP_CONFIG.socials.github}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg border border-zinc-800 bg-zinc-900/80 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 flex items-center justify-center transition"
              title="GitHub"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.44 22 12.017 22 6.484 17.522 2 12 2z"/>
              </svg>
            </a>
            <a
              href={APP_CONFIG.socials.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg border border-zinc-800 bg-zinc-900/80 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 flex items-center justify-center transition"
              title="LinkedIn"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
              </svg>
            </a>
            {APP_CONFIG.socials.twitter && (
              <a
                href={APP_CONFIG.socials.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 rounded-lg border border-zinc-800 bg-zinc-900/80 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 flex items-center justify-center transition"
                title="X (formerly Twitter)"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            )}
            {APP_CONFIG.socials.medium && (
              <a
                href={APP_CONFIG.socials.medium}
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 rounded-lg border border-zinc-800 bg-zinc-900/80 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 flex items-center justify-center transition"
                title="Medium"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42zm3.04 0c0 3.25-.33 5.9-0.73 5.9-.4 0-.73-2.65-.73-5.9s.33-5.9.73-5.9c.4 0 .73 2.65.73 5.9z"/>
                </svg>
              </a>
            )}
            <a
              href={APP_CONFIG.socials.upwork}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg border border-zinc-800 bg-zinc-900/80 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 flex items-center justify-center transition"
              title="Upwork"
            >
              <svg role="img" viewBox="0 0 24 24" fill="currentColor" class="w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.543-2.548V3.56H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-.354c.511 1.365 1.251 2.946 2.222 4.486l-1.637 7.692h2.825l1.197-5.636c.99.637 2.115 1.009 3.39 1.009 3.037 0 5.51-2.435 5.51-5.51-.001-3.075-2.473-5.51-5.51-5.51z" />
              </svg>
            </a>
            <a
              href={`mailto:${APP_CONFIG.author.email}`}
              class="w-9 h-9 rounded-lg border border-zinc-800 bg-zinc-900/80 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 flex items-center justify-center transition"
              title="Gmail"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>
              </svg>
            </a>
          </div>

          <a
            href="/mahendra_sh_resume.pdf"
            download="mahendra_sh_resume.pdf"
            class="px-5 py-2.5 rounded-xl bg-zinc-50 hover:bg-zinc-200 text-zinc-950 text-xs font-bold font-mono transition border border-zinc-200 shadow-md hover:scale-[1.01] cursor-pointer flex items-center gap-2"
          >
            <span>Get Resume PDF</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Bobbing Floating Animation */
  @keyframes floatAnimation {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  /* Wavy Liquid Border Animation */
  @keyframes waveAnimation {
    0% {
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    }
    25% {
      border-radius: 40% 60% 50% 40% / 40% 40% 50% 60%;
    }
    50% {
      border-radius: 30% 60% 70% 40% / 50% 60% 30%;
    }
    75% {
      border-radius: 50% 30% 40% 60% / 30% 70% 60% 50%;
    }
    100% {
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    }
  }

  /* Spin animation for border gradient */
  @keyframes spinFrame {
    0% {
      transform: rotate(0deg) scale(1.5);
    }
    100% {
      transform: rotate(360deg) scale(1.5);
    }
  }

  .profile-container {
    animation: floatAnimation 6s ease-in-out infinite;
  }

  .wavy-profile-image {
    animation: waveAnimation 8s ease-in-out infinite;
  }

  /* Rotating neon gradient effect */
  .animate-spin-frame {
    animation: spinFrame 6s linear infinite;
  }
</style>

<script>
  function runTypewriter() {
    const words = ["Full-Stack Developer", "Specialist Programmer", "Backend Engineer"];
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const el = document.getElementById('typewriter');
    if (!el) return;

    function type() {
      const currentWord = words[wordIndex];
      if (isDeleting) {
        el.textContent = currentWord.substring(0, charIndex - 1);
        charIndex--;
      } else {
        el.textContent = currentWord.substring(0, charIndex + 1);
        charIndex++;
      }

      let typeSpeed = isDeleting ? 40 : 80;

      if (!isDeleting && charIndex === currentWord.length) {
        typeSpeed = 2000; // Pause at end of word
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        typeSpeed = 350; // Pause before typing next word
      }

      setTimeout(type, typeSpeed);
    }

    type();
  }

  // Initial load
  runTypewriter();
  
  // Re-run typewriter on Astro page navigation swaps
  document.addEventListener('astro:after-swap', runTypewriter);
</script>
